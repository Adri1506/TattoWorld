# ==============================================================
# Environment Variables - TattoWorld
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ==============================================================

# --------------------------------------------------------------
# Site Configuration
# --------------------------------------------------------------

# Site URL (used for SEO, Open Graph, etc.)
# Example: https://tattoworld.cl
SITE_URL=https://tattoworld.cl

# Site Name (used in meta tags and Schema.org)
SITE_NAME=TattoWorld

# --------------------------------------------------------------
# Contact Information
# --------------------------------------------------------------

# WhatsApp phone number (format: +56912345678)
# This number is displayed on the WhatsApp floating button
WHATSAPP_PHONE=+56912345678

# Business email (used in Schema.org and contact info)
BUSINESS_EMAIL=contacto@tattoworld.cl

# Business phone (used in Schema.org and contact info)
BUSINESS_PHONE=+56912345678

# Business address (used in Schema.org)
BUSINESS_ADDRESS=Santiago, Chile

# --------------------------------------------------------------
# Formspree Configuration
# --------------------------------------------------------------

# Formspree form ID for contact form submissions
# Get yours at: https://formspree.io
FORMSPREE_FORM_ID=xrgbqzqn

# --------------------------------------------------------------
# Analytics (Optional)
# --------------------------------------------------------------

# Google Analytics ID (optional, leave empty if not used)
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --------------------------------------------------------------
# Social Media (Optional)
# --------------------------------------------------------------

# Instagram URL (optional)
# INSTAGRAM_URL=https://instagram.com/tattoworld

# Facebook URL (optional)
# FACEBOOK_URL=https://facebook.com/tattoworld

# --------------------------------------------------------------
# Deployment (Optional)
# --------------------------------------------------------------

# Deploy target (github-pages, vercel, netlify, railway, docker)
# DEPLOY_TARGET=github-pages

# GitHub repository (for GitHub Pages)
# GITHUB_REPO=username/tattoworld
